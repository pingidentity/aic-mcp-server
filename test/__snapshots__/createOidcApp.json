{
  "name": "createOidcApp",
  "title": "Create OIDC App",
  "description": "Creates an OIDC application. Only supply the oauth2Client fields you want to set; defaults are applied for the rest.",
  "scopes": [
    "fr:am:*",
    "fr:idm:*"
  ],
  "inputSchema": {
    "realm": {
      "_def": {
        "values": [
          "alpha",
          "bravo"
        ],
        "typeName": "ZodEnum",
        "description": "The realm"
      },
      "~standard": {
        "version": 1,
        "vendor": "zod"
      }
    },
    "name": {
      "_def": {
        "checks": [
          {
            "kind": "min",
            "value": 1
          }
        ],
        "typeName": "ZodString",
        "coerce": false,
        "description": "The application display name"
      },
      "~standard": {
        "version": 1,
        "vendor": "zod"
      }
    },
    "clientId": {
      "_def": {
        "schema": {
          "_def": {
            "schema": {
              "_def": {
                "checks": [
                  {
                    "kind": "min",
                    "value": 1,
                    "message": "Value cannot be empty"
                  }
                ],
                "typeName": "ZodString",
                "coerce": false
              },
              "~standard": {
                "version": 1,
                "vendor": "zod"
              }
            },
            "typeName": "ZodEffects",
            "effect": {
              "type": "refinement"
            }
          },
          "~standard": {
            "version": 1,
            "vendor": "zod"
          }
        },
        "typeName": "ZodEffects",
        "effect": {
          "type": "refinement"
        },
        "description": "The OAuth2 client ID used in protocol flows"
      },
      "~standard": {
        "version": 1,
        "vendor": "zod"
      }
    },
    "owners": {
      "_def": {
        "type": {
          "_def": {
            "keyType": {
              "_def": {
                "checks": [],
                "typeName": "ZodString",
                "coerce": false
              },
              "~standard": {
                "version": 1,
                "vendor": "zod"
              }
            },
            "valueType": {
              "_def": {
                "typeName": "ZodAny"
              },
              "~standard": {
                "version": 1,
                "vendor": "zod"
              },
              "_any": true
            },
            "typeName": "ZodRecord"
          },
          "~standard": {
            "version": 1,
            "vendor": "zod"
          }
        },
        "minLength": {
          "value": 1
        },
        "maxLength": null,
        "exactLength": null,
        "typeName": "ZodArray",
        "description": "Application owners. Example: [{\"_ref\": \"managed/alpha_user/USER_ID\"}]"
      },
      "~standard": {
        "version": 1,
        "vendor": "zod"
      }
    },
    "oauth2Client": {
      "_def": {
        "innerType": {
          "_def": {
            "keyType": {
              "_def": {
                "checks": [],
                "typeName": "ZodString",
                "coerce": false
              },
              "~standard": {
                "version": 1,
                "vendor": "zod"
              }
            },
            "valueType": {
              "_def": {
                "typeName": "ZodAny"
              },
              "~standard": {
                "version": 1,
                "vendor": "zod"
              },
              "_any": true
            },
            "typeName": "ZodRecord"
          },
          "~standard": {
            "version": 1,
            "vendor": "zod"
          }
        },
        "typeName": "ZodOptional",
        "description": "OIDC client configuration. Each property uses the wrapper format {\"inherited\": false, \"value\": <val>}, nested under config sections. Example: {\"coreOAuth2ClientConfig\": {\"redirectionUris\": {\"inherited\": false, \"value\": [\"https://example.com/callback\"]}}}"
      },
      "~standard": {
        "version": 1,
        "vendor": "zod"
      }
    }
  }
}